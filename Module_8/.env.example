# Copy to .env and fill in values (see NEO4J_SETUP.md and LLM_MODEL_SETUP.md)
# Do not commit .env to version control.
# NEO4J_PASSWORD must match NEO4J_AUTH in Docker (Option C): neo4j/<password>

NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CourseNeo4j2026!
NEO4J_DATABASE=neo4j

# ollama | openai
LLM_BACKEND=ollama

# Ollama path (notebook calls Module_8/ollama_model_runner.py)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TEMPERATURE=0
OLLAMA_MAX_TOKENS=4096

# Notebook lab limits (articles = one LLM call each)
LAB_MAX_ARTICLES=5
LAB_SCHEMA_ARTICLES=8

# OpenAI path
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
